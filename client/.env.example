# Optional: production API origin (no trailing slash). Baked into the static build; overrides same-origin /api.
# Example: https://your-api.onrender.com
# VITE_API_BASE=

# Optional: Vite `base` path for GitHub Pages project sites (leading slash, trailing slash). Example: /SureWouldYouLikeMeTo/
# Leave unset for root hosting (e.g. custom domain or Vercel default).
# VITE_BASE_PATH=
