# Copy to ".env" in this folder (never commit .env).

# ── HKUST / Colab-style (matches os.environ AZURE_* setup) ──────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://hkust.azure-api.net
# Chat completion deployment (optional if you only need DALL·E images via AZURE_IMAGE_DEPLOYMENT).
AZURE_DEPLOYMENT_NAME=gpt-4o
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Optional: set to your DALL·E 3 deployment name (uncomment / fill to enable outcome images)
AZURE_IMAGE_DEPLOYMENT=dall-e-3

# Optional: use Azure OpenAI Python SDK for DALL·E (HKUST gateway); requires `pip install openai`
OPENAI_IMAGES_USE_AZURE_SDK=true

# ── Optional overrides (usually unnecessary if AZURE_* is set) ────────────
# OPENAI_API_KEY= 
# OPENAI_BASE_URL=
# OPENAI_MODEL=
# OPENAI_AUTH_STYLE=azure
# OPENAI_API_VERSION=2025-02-01-preview
# OPENAI_IMAGES_ENDPOINT=
# OPENAI_IMAGES_API_VERSION=2025-02-01-preview

# ── MiniMax image-01 (optional: run `python scripts/minimax_image_generation.py` from `server/`) ──
MINIMAX_API_KEY=
# Optional: absolute or relative path to a local reference image (PNG/JPEG, <10MB). Sent as a data URL.
# If unset, uses scripts/references/south-park-style-reference.png when that file exists.
# MINIMAX_REFERENCE_IMAGE_PATH=scripts/references/south-park-style-reference.png
# If no local file: HTTPS URL for subject_reference (else MiniMax CDN demo).
# MINIMAX_SUBJECT_IMAGE_URL=https://cdn.hailuoai.com/prod/2025-08-12-17/video_cover/1754990600020238321-411603868533342214-cover.jpg
# Optional: override the default “style like reference” prompt.
# MINIMAX_PROMPT=A girl at a library window in flat cutout animation style matching the reference.
# MINIMAX_ASPECT_RATIO=16:9
