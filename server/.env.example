# Copy to ".env" in this folder (never commit .env).

# ── HKUST / Colab-style (matches os.environ AZURE_* setup) ──────────────────
AZURE_OPENAI_API_KEY= 8592986358204a60b0981205358742f5
AZURE_OPENAI_ENDPOINT=https://hkust.azure-api.net
# Chat completion deployment (optional if you only need DALL·E images via AZURE_IMAGE_DEPLOYMENT).
AZURE_DEPLOYMENT_NAME=gpt-4o
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Optional: set to your DALL·E 3 deployment name (uncomment / fill to enable outcome images)
AZURE_IMAGE_DEPLOYMENT=dall-e-3

# Optional: use Azure OpenAI Python SDK for DALL·E (HKUST gateway); requires `pip install openai`
OPENAI_IMAGES_USE_AZURE_SDK=false

# ── Optional overrides (usually unnecessary if AZURE_* is set) ────────────
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
# OPENAI_AUTH_STYLE=azure
# OPENAI_API_VERSION=2025-02-01-preview
# OPENAI_IMAGES_ENDPOINT=
# OPENAI_IMAGES_API_VERSION=2025-02-01-preview
