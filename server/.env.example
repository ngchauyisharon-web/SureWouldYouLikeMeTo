# Copy to ".env" in this folder (never commit .env).
#
# HKUST gateway — aligns with Colab:
#   client = AzureOpenAI(
#     azure_endpoint="https://hkust.azure-api.net",
#     api_key=<AZURE_OPENAI_API_KEY>,
#     api_version="2025-02-01-preview",
#   )
#
# Non-secret defaults (endpoint, deployment names) are also applied in code via
# os.environ.setdefault — see server/app/config.py _bootstrap_azure_env_from_colab_defaults.
# You must set the API key locally:

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://hkust.azure-api.net
AZURE_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Optional: DALL·E 3 deployment for generated scenario art
AZURE_IMAGE_DEPLOYMENT=dall-e-3

# Prefer Azure OpenAI SDK for DALL·E (HKUST); set false to use raw HTTP first only
OPENAI_IMAGES_USE_AZURE_SDK=true

# Optional overrides (usually unnecessary if AZURE_* is set)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
# OPENAI_AUTH_STYLE=azure
# OPENAI_API_VERSION=2025-02-01-preview
# OPENAI_IMAGES_ENDPOINT=
# OPENAI_IMAGES_API_VERSION=2025-02-01-preview
