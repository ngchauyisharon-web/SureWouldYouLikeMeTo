# Copy to ".env" in this folder (never commit .env).

# ── HKUST / Colab-style (matches os.environ AZURE_* setup) ──────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://hkust.azure-api.net
# Chat completion deployment (optional if you only need DALL·E images via AZURE_IMAGE_DEPLOYMENT).
AZURE_DEPLOYMENT_NAME=gpt-4o
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Optional: set to your DALL·E 3 deployment name (uncomment / fill to enable outcome images)
AZURE_IMAGE_DEPLOYMENT=dall-e-3

# Optional: use Azure OpenAI Python SDK for DALL·E (HKUST gateway); requires `pip install openai`
OPENAI_IMAGES_USE_AZURE_SDK=true

# ── Image provider ─────────────────────────────────────────────────────────
# openai = DALL·E via Azure/OpenAI (above). minimax = MiniMax image-01 (requires MINIMAX_API_KEY).
IMAGE_PROVIDER=openai

# MiniMax text-to-image (https://platform.minimax.io/docs/api-reference/image-generation-t2i)
MINIMAX_API_KEY=
# Optional overrides:
# MINIMAX_API_BASE=https://api.minimax.io
# MINIMAX_IMAGE_MODEL=image-01

# Optional: appended to the fixed cutout-cartoon style block in image prompts (use only if your gateway allows).
# IMAGE_STYLE_LABEL=South Park style characters

# ── Optional overrides (usually unnecessary if AZURE_* is set) ────────────
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
# OPENAI_AUTH_STYLE=azure
# OPENAI_API_VERSION=2025-02-01-preview
# OPENAI_IMAGES_ENDPOINT=
# OPENAI_IMAGES_API_VERSION=2025-02-01-preview

# Comma-separated browser origins for CORS (add your GitHub Pages URL when deploying the static site).
# Example: https://yourname.github.io,https://yourname.github.io/SureWouldYouLikeMeTo
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
